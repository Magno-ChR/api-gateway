{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "security-api": {
        "ClusterId": "security-api",
        "Match": { "Path": "/api/security/{**catch-all}" }
      },
      "patients-api": {
        "ClusterId": "patients-api",
        "Match": { "Path": "/api/patient/{**catch-all}" }
      },
      "kitchen-api": {
        "ClusterId": "kitchen-api",
        "Match": { "Path": "/api/kitchen/{**catch-all}" }
      },
      "logistic-api": {
        "ClusterId": "logistic-api",
        "Match": { "Path": "/api/logistic/{**catch-all}" }
      },
      "plans-api": {
        "ClusterId": "plans-api",
        "Match": { "Path": "/api/plans/{**catch-all}" }
      },
      "calendar-api": {
        "ClusterId": "calendar-api",
        "Match": { "Path": "/api/calendario/{**catch-all}" }
      }
    },
    "Clusters": {
      "security-api": {
        "Destinations": {
          "security-backend": { "Address": "http://localhost:5001" }
        }
      },
      "patients-api": {
        "Destinations": {
          "patients-backend": { "Address": "http://localhost:5002" }
        }
      },
      "kitchen-api": {
        "Destinations": {
          "kitchen-backend": { "Address": "http://localhost:5005" }
        }
      },
      "logistic-api": {
        "Destinations": {
          "logistic-backend": { "Address": "http://localhost:5006" }
        }
      },
      "plans-api": {
        "Destinations": {
          "plans-backend": { "Address": "http://localhost:5007" }
        }
      },
      "calendar-api": {
        "Destinations": {
          "calendar-backend": { "Address": "http://calendario-webapi:7020" }
        }
      }
    }
  }
}
